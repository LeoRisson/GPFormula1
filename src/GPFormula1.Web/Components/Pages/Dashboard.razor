@page "/"
@using GPFormula1.Web.Models
@inject HttpClient Http
@rendermode InteractiveServer

<PageTitle>Dashboard - F1 Season Tracker</PageTitle>

<div class="dashboard-container">
    <!-- Header -->
    <div class="dashboard-header">
        <h1 class="dashboard-title">Dashboard</h1>
        <p class="dashboard-subtitle">Visão geral da temporada 2024 de Fórmula 1</p>
    </div>

    <!-- Stats Grid -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-content">
                <div>
                    <p class="stat-label">Temporada Atual</p>
                    <p class="stat-value">@currentSeason</p>
                </div>
                <div class="stat-icon bg-blue">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                </div>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-content">
                <div>
                    <p class="stat-label">Corridas Realizadas</p>
                    <p class="stat-value">@racesCompleted/24</p>
                </div>
                <div class="stat-icon bg-red">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"></path><line x1="4" y1="22" x2="4" y2="15"></line></svg>
                </div>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-content">
                <div>
                    <p class="stat-label">Pilotos Ativos</p>
                    <p class="stat-value">@driversCount</p>
                </div>
                <div class="stat-icon bg-green">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                </div>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-content">
                <div>
                    <p class="stat-label">Equipes</p>
                    <p class="stat-value">@teamsCount</p>
                </div>
                <div class="stat-icon bg-purple">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                </div>
            </div>
        </div>
    </div>

    <!-- Two Column Layout -->
    <div class="content-grid">
        <!-- Upcoming Race -->
        <div class="upcoming-race-card">
            <div class="upcoming-race-header">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"></path><line x1="4" y1="22" x2="4" y2="15"></line></svg>
                <h2>Próxima Corrida</h2>
            </div>
            @if (nextRace != null)
            {
                <div class="upcoming-race-content">
                    <div>
                        <h3 class="race-name">@nextRace.Nome</h3>
                        <p class="race-date">@nextRace.Data.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>
                    <div class="race-info">
                        <p class="race-label">Local</p>
                        <p class="race-value">@nextRace.Local</p>
                    </div>
                    <div class="race-info">
                        <p class="race-label">Circuito</p>
                        <p class="race-value">@nextRace.Circuito</p>
                    </div>
                </div>
            }
        </div>

        <!-- Driver Standings -->
        <div class="standings-card">
            <div class="standings-header">
                <div class="standings-title">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="trophy-icon"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"></path><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"></path><path d="M4 22h16"></path><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"></path><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"></path><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"></path></svg>
                    <h2>Classificação de Pilotos</h2>
                </div>
            </div>
            <div class="standings-list">
                @foreach (var driver in top5Drivers)
                {
                    <div class="standing-item">
                        <div class="standing-driver">
                            <div class="position-badge">@driver.Position</div>
                            <div>
                                <p class="driver-name">@driver.DriverName</p>
                                <p class="team-name">@driver.TeamName</p>
                            </div>
                        </div>
                        <div class="points-section">
                            <p class="points-value">@driver.Points</p>
                            <p class="points-label">pontos</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Constructor Standings -->
    <div class="constructor-standings">
        <div class="constructor-header">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
            <h2>Classificação de Construtores</h2>
        </div>
        <div class="constructor-grid">
            @foreach (var team in top4Teams)
            {
                <div class="constructor-card" style="border-left-color: @team.Color">
                    <div class="constructor-position">
                        <span class="position-number">#@team.Position</span>
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="@team.Color" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                    </div>
                    <h3 class="constructor-name">@team.TeamName</h3>
                    <p class="constructor-points">@team.Points</p>
                    <p class="constructor-label">pontos</p>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private int currentSeason = 2024;
    private int racesCompleted = 5;
    private int driversCount = 20;
    private int teamsCount = 10;
    
    private GrandePremio? nextRace;
    private List<DriverStanding> top5Drivers = new();
    private List<TeamStanding> top4Teams = new();

    protected override async Task OnInitializedAsync()
    {
        // Por enquanto dados mockados - depois vamos buscar da API
        nextRace = new GrandePremio
        {
            Nome = "GP de Mônaco",
            Data = new DateTime(2024, 5, 26, 15, 0, 0),
            Local = "Monte Carlo, Mônaco",
            Circuito = "Circuit de Monaco"
        };

        top5Drivers = new List<DriverStanding>
        {
            new() { Position = 1, DriverName = "Max Verstappen", TeamName = "Red Bull Racing", Points = 125 },
            new() { Position = 2, DriverName = "Lewis Hamilton", TeamName = "Mercedes", Points = 98 },
            new() { Position = 3, DriverName = "Charles Leclerc", TeamName = "Ferrari", Points = 87 },
            new() { Position = 4, DriverName = "Lando Norris", TeamName = "McLaren", Points = 76 },
            new() { Position = 5, DriverName = "Carlos Sainz", TeamName = "Ferrari", Points = 72 }
        };

        top4Teams = new List<TeamStanding>
        {
            new() { Position = 1, TeamName = "Red Bull Racing", Points = 198, Color = "#1E40AF" },
            new() { Position = 2, TeamName = "Ferrari", Points = 159, Color = "#DC2626" },
            new() { Position = 3, TeamName = "Mercedes", Points = 142, Color = "#06B6D4" },
            new() { Position = 4, TeamName = "McLaren", Points = 124, Color = "#F97316" }
        };
    }
}
